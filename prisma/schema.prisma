// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ==========================
// ENUMS
// ==========================

enum UserRole {
  SCHOOL_OWNER
  STAFF
  PARENT
  STUDENT
}

enum DomainType {
  SCHOOL_PORTAL
  STUDENTS
  PARENTS
}

enum StaffRole {
  ADMIN
  TEACHER
  ACCOUNTANT
  PRINCIPAL
}

enum ParentRelationship {
  FATHER
  MOTHER
  GUARDIAN
}

enum SessionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CategoryType {
  PRE_SCHOOL
  PRIMARY
  SECONDARY
  TERTIARY
}

enum EnrollmentStatus {
  ACTIVE
  REPEATED
  WITHDRAWN
}

enum SubjectPriority {
  REQUIRED
  OPTIONAL
  ELECTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum ExamType {
  MIDTERM
  ENDTERM
  MOCK
  CUSTOM
}

enum ExamStatus {
  DRAFT
  OPEN
  LOCKED
  PUBLISHED
}

enum ResultSheetType {
  TERM
  ANNUAL
  CUSTOM
}

enum ResultSheetStatus {
  DRAFT
  PROCESSING
  PUBLISHED
  ARCHIVED
}

// ==========================
// AUTHENTICATION & USERS
// ==========================

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  otherName    String?  @map("other_name")
  phone        String?  @unique
  passwordHash String?  @map("password_hash")
  role         UserRole
  isActive     Boolean  @default(false) @map("is_active") // Default false for OTP flow
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ownedGroups    SchoolGroup[]
  ownedSchools   School[]
  staffProfiles  StaffProfile[]
  parentProfiles ParentProfile[]
  studentProfile Student?

  @@map("users")
}

// ==========================
// MEDIA TRACKING
// ==========================
model Media {
  id        String   @id @default(uuid())
  url       String
  fileKey   String   // The R2 path (e.g., "logos/123.webp")
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ==========================
// SCHOOLS
// ==========================

model School {
  id            Int      @id @default(autoincrement())
  schoolGroupId Int?     @map("school_group_id")
  name          String
  slug          String   @unique
  address       String?  @db.Text
  schoolType    String?  @map("school_type")
  ownerUserId   Int      @map("owner_user_id")
  
  // Branding
  logoUrl       String?  @map("logo_url")
  primaryColor  String?  @map("primary_color")
  secondaryColor String? @map("secondary_color")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  schoolGroup      SchoolGroup?      @relation(fields: [schoolGroupId], references: [id])
  owner            User              @relation(fields: [ownerUserId], references: [id])
  staffProfiles    StaffProfile[]
  parentProfiles   ParentProfile[]
  students         Student[]
  academicSessions AcademicSession[]
  classLevels      ClassLevel[]
  subjects         Subject[]
  domains          SchoolDomain[]

  @@map("schools")
  classCategories ClassCategory[]
}

// School Group model for school branches
model SchoolGroup {
  id          Int      @id @default(autoincrement())
  name        String
  ownerUserId Int      @map("owner_user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner   User     @relation(fields: [ownerUserId], references: [id])
  schools School[]

  @@map("school_groups")
}

// The SchoolDomain Model
model SchoolDomain {
  id          String     @id @default(uuid())
  schoolId    Int        @map("school_id")
  domain      String     @unique // e.g., portal.greensprings.edu.ng
  type        DomainType @default(SCHOOL_PORTAL)
  isPrimary   Boolean    @default(false) @map("is_primary")
  isVerified  Boolean    @default(false) @map("is_verified")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relation to the School model
  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_domains") // This ensures the DB table is named school_domains
  @@index([schoolId])     // Faster lookups when querying domains by school
}

// ==========================
// PROFILES
// ==========================

model StaffProfile {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  schoolId  Int       @map("school_id")
  role      StaffRole
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Overrides
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  passwordHash String?   @map("password_hash")

  user   User   @relation(fields: [userId], references: [id])
  school School @relation(fields: [schoolId], references: [id])
  
  // Relations to academic models for teacher assignments
  classArms ClassArm[] @relation("ClassTeacher")
  classSubjects ClassSubject[] @relation("SubjectTeacher")

  @@unique([userId, schoolId])
  @@map("staff_profiles")
}

model ParentProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  schoolId  Int      @map("school_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Overrides
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  passwordHash String?   @map("password_hash")

  user     User            @relation(fields: [userId], references: [id])
  school   School          @relation(fields: [schoolId], references: [id])
  students ParentStudent[]

  @@unique([userId, schoolId])
  @@map("parent_profiles")
}

model Student {
  id          Int      @id @default(autoincrement())
  userId      Int?     @unique @map("user_id")
  schoolId    Int      @map("school_id")
  admissionNo String   @map("admission_no")
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  gender      String?
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  isActive  Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  passwordHash String?   @map("password_hash")

  user        User?           @relation(fields: [userId], references: [id])
  school      School          @relation(fields: [schoolId], references: [id])
  parents     ParentStudent[]
  enrollments Enrollment[]

  // Academic constraint
  @@unique([schoolId, admissionNo]) 
  // Auth/Login logic
  @@unique([userId, schoolId])
  @@map("students")
}

model ParentStudent {
  parentProfileId Int                @map("parent_profile_id")
  studentId       Int                @map("student_id")
  relationship    ParentRelationship
  createdAt       DateTime           @default(now()) @map("created_at")

  parent  ParentProfile @relation(fields: [parentProfileId], references: [id])
  student Student       @relation(fields: [studentId], references: [id])

  @@id([parentProfileId, studentId])
  @@map("parent_students")
}

// ==========================
// ACADEMIC STRUCTURE
// ==========================

model AcademicSession {
  id        Int           @id @default(autoincrement())
  schoolId  Int           @map("school_id")
  name      String 
  isActive  Boolean       @default(false) @map("is_active")
  status    SessionStatus
  startsAt  DateTime?     @map("starts_at") @db.Date
  endsAt    DateTime?     @map("ends_at") @db.Date
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  school             School              @relation(fields: [schoolId], references: [id])
  terms              Term[]
  enrollments        Enrollment[]
  classSubjects      ClassSubject[]
  attendanceSessions AttendanceSession[]

  // @@unique([schoolId, isActive])
  @@map("academic_sessions")
  examSessions ExamSession[]
}

model Term {
  id                Int      @id @default(autoincrement())
  academicSessionId Int      @map("academic_session_id")
  name              String 
  orderIndex        Int      @map("order_index")
  isActive          Boolean  @default(false) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  academicSession    AcademicSession     @relation(fields: [academicSessionId], references: [id])
  attendanceSessions AttendanceSession[]

  @@unique([academicSessionId, name])
  @@map("terms")
  examSessions ExamSession[]
}

model ClassCategory {
  id        Int          @id @default(autoincrement())
  schoolId  Int          @map("school_id")
  name      String       // e.g., "Senior Secondary", "Lower Primary"
  type      CategoryType // For system-wide logic
  createdAt DateTime     @default(now()) @map("created_at")

  school      School       @relation(fields: [schoolId], references: [id])
  classLevels ClassLevel[]

  @@unique([schoolId, name])
  @@map("class_categories")
}

model ClassLevel {
  id         Int      @id @default(autoincrement())
  schoolId   Int      @map("school_id")
  classCategoryId Int?      @map("class_category_id")
  name       String 
  levelOrder Int      @map("level_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school    School     @relation(fields: [schoolId], references: [id])
  classArms ClassArm[]

  category   ClassCategory? @relation(fields: [classCategoryId], references: [id])

  @@unique([schoolId, levelOrder])
  @@map("class_levels")
  scoreDivisionConfigs ScoreDivisionConfig[]
  examSessionClassLevels ExamSessionClassLevel[]
}

model ClassArm {
  id           Int      @id @default(autoincrement())
  classLevelId Int      @map("class_level_id")
  name         String 
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Link to StaffProfile for the Class Teacher
  classTeacherId Int?   @map("class_teacher_id")
  classTeacher   StaffProfile? @relation("ClassTeacher", fields: [classTeacherId], references: [id])

  classLevel         ClassLevel          @relation(fields: [classLevelId], references: [id])
  enrollments        Enrollment[]
  classSubjects      ClassSubject[]
  attendanceSessions AttendanceSession[]

  @@unique([classLevelId, name])
  @@map("class_arms")
}

model Enrollment {
  id                Int              @id @default(autoincrement())
  studentId         Int              @map("student_id")
  classArmId        Int              @map("class_arm_id")
  academicSessionId Int              @map("academic_session_id")
  enrollmentStatus  EnrollmentStatus @map("enrollment_status")
  createdAt         DateTime         @default(now()) @map("created_at")

  student           Student            @relation(fields: [studentId], references: [id])
  classArm          ClassArm           @relation(fields: [classArmId], references: [id])
  academicSession   AcademicSession    @relation(fields: [academicSessionId], references: [id])
  attendanceRecords AttendanceRecord[]

  @@unique([studentId, academicSessionId])
  @@map("enrollments")
}

// ==========================
// SUBJECTS & ATTENDANCE
// ==========================

model Subject {
  id        Int      @id @default(autoincrement())
  schoolId  Int      @map("school_id")
  name      String
  code      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school        School         @relation(fields: [schoolId], references: [id])
  classSubjects ClassSubject[]

  @@unique([schoolId, name])
  @@map("subjects")
}

model ClassSubject {
  id                Int             @id @default(autoincrement())
  subjectId         Int             @map("subject_id")
  classArmId        Int             @map("class_arm_id")
  academicSessionId Int             @map("academic_session_id")
  priority          SubjectPriority
  isExamSubject     Boolean         @default(true) @map("is_exam_subject")
  createdAt         DateTime        @default(now()) @map("created_at")

  subject         Subject         @relation(fields: [subjectId], references: [id])
  classArm        ClassArm        @relation(fields: [classArmId], references: [id])
  academicSession AcademicSession @relation(fields: [academicSessionId], references: [id])

  // Link to StaffProfile for the Subject Teacher
  teacherId Int? @map("teacher_id")
  teacher   StaffProfile? @relation("SubjectTeacher", fields: [teacherId], references: [id])

  @@unique([subjectId, classArmId, academicSessionId])
  @@map("class_subjects")
}

model AttendanceSession {
  id                Int      @id @default(autoincrement())
  classArmId        Int      @map("class_arm_id")
  academicSessionId Int      @map("academic_session_id")
  termId            Int      @map("term_id")
  attendanceDate    DateTime @map("attendance_date") @db.Date
  createdAt         DateTime @default(now()) @map("created_at")

  classArm        ClassArm           @relation(fields: [classArmId], references: [id])
  academicSession AcademicSession    @relation(fields: [academicSessionId], references: [id])
  term            Term               @relation(fields: [termId], references: [id])
  records         AttendanceRecord[]

  @@unique([classArmId, academicSessionId, attendanceDate])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                  Int              @id @default(autoincrement())
  attendanceSessionId Int              @map("attendance_session_id")
  enrollmentId        Int              @map("enrollment_id")
  status              AttendanceStatus
  createdAt           DateTime         @default(now()) @map("created_at")

  attendanceSession AttendanceSession @relation(fields: [attendanceSessionId], references: [id])
  enrollment        Enrollment        @relation(fields: [enrollmentId], references: [id])

  @@unique([attendanceSessionId, enrollmentId])
  @@map("attendance_records")
}



// --- ASSESSMENT LAYER ---

model ExamSession {
  id                Int      @id @default(autoincrement())
  academicSessionId Int      @map("academic_session_id")
  termId            Int      @map("term_id")
  
  title             String
  examType          ExamType    @map("exam_type")
  status            ExamStatus  @default(DRAFT)
  
  openedAt          DateTime? @map("opened_at")
  lockedAt          DateTime? @map("locked_at")
  publishedAt       DateTime? @map("published_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  // Relations
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])
  term              Term            @relation(fields: [termId], references: [id])
  
  // New Join Table for school-wide but level-specific participation
  participatingLevels ExamSessionClassLevel[]
  
  scoreConfigs      ScoreDivisionConfig[]
  subjectScores     StudentSubjectScore[]
  gradingScales     GradingScale[]
  resultSheetLinks  ResultSheetExamSession[]

  @@map("exam_sessions")
}

model ExamSessionClassLevel {
  id            Int      @id @default(autoincrement())
  examSessionId Int      @map("exam_session_id")
  classLevelId  Int      @map("class_level_id")
  createdAt     DateTime @default(now()) @map("created_at")

  examSession   ExamSession @relation(fields: [examSessionId], references: [id])
  classLevel    ClassLevel  @relation(fields: [classLevelId], references: [id])

  @@unique([examSessionId, classLevelId])
  @@map("exam_session_class_levels")
}

model ScoreDivisionConfig {
  id            Int      @id @default(autoincrement())
  examSessionId Int      @map("exam_session_id")
  classLevelId  Int      @map("class_level_id") // Divisions can still vary by level
  
  name          String   
  maxScore      Decimal  @map("max_score") @db.Decimal(5, 2)
  weight        Decimal? @db.Decimal(5, 2)
  orderIndex    Int      @map("order_index")
  createdAt     DateTime @default(now()) @map("created_at")

  examSession   ExamSession @relation(fields: [examSessionId], references: [id])
  classLevel    ClassLevel  @relation(fields: [classLevelId], references: [id])
  studentDivisions StudentScoreDivision[]

  @@map("score_division_configs")
}

model StudentSubjectScore {
  id            Int      @id @default(autoincrement())
  examSessionId Int      @map("exam_session_id")
  studentId     Int      @map("student_id")
  subjectId     Int      @map("subject_id")
  
  totalScore    Decimal  @map("total_score") @db.Decimal(5, 2)
  grade         String?
  remark        String?
  isAbsent      Boolean  @default(false) @map("is_absent")
  createdAt     DateTime @default(now()) @map("created_at")

  examSession   ExamSession @relation(fields: [examSessionId], references: [id])
  divisions     StudentScoreDivision[]

  @@unique([examSessionId, studentId, subjectId])
  @@map("student_subject_scores")
}


model StudentScoreDivision {
  id                     Int      @id @default(autoincrement())
  studentSubjectScoreId  Int      @map("student_subject_score_id")
  scoreDivisionConfigId  Int      @map("score_division_config_id")
  score                  Decimal  @db.Decimal(5, 2)
  createdAt              DateTime @default(now()) @map("created_at")

  subjectScore           StudentSubjectScore @relation(fields: [studentSubjectScoreId], references: [id])
  config                 ScoreDivisionConfig @relation(fields: [scoreDivisionConfigId], references: [id])

  @@unique([studentSubjectScoreId, scoreDivisionConfigId])
  @@map("student_score_divisions")
}

// --- AGGREGATION LAYER (REPORT SHEETS) ---

model ResultSheet {
  id                Int      @id @default(autoincrement())
  academicSessionId Int      @map("academic_session_id")
  termId            Int?     @map("term_id") // NULL for Annual
  classLevelId      Int      @map("class_level_id")
  classArmId        Int?     @map("class_arm_id")
  
  type          ResultSheetType
  status        ResultSheetStatus @default(DRAFT)
  
  publishedAt       DateTime? @map("published_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  examSessions      ResultSheetExamSession[]
  summaries         StudentResultSummary[]
  cumulativeSummaries StudentCumulativeSummary[]
  skillAssessments  StudentSkillAssessment[]

  @@map("result_sheets")
}

model ResultSheetExamSession {
  id            Int      @id @default(autoincrement())
  resultSheetId Int      @map("result_sheet_id")
  examSessionId Int      @map("exam_session_id")
  weight        Decimal  @default(1.0) @db.Decimal(5, 2)

  resultSheet   ResultSheet @relation(fields: [resultSheetId], references: [id])
  examSession   ExamSession @relation(fields: [examSessionId], references: [id])

  @@unique([resultSheetId, examSessionId])
  @@map("result_sheet_exam_sessions")
}


// --- GRADING LAYER ---

model GradingScale {
  id            Int      @id @default(autoincrement())
  examSessionId Int      @map("exam_session_id")
  classLevelId  Int      @map("class_level_id")
  name          String   // e.g., "WAEC Standard" or "Lower Primary Scale"
  createdAt     DateTime @default(now()) @map("created_at")

  examSession   ExamSession      @relation(fields: [examSessionId], references: [id])
  boundaries    GradeBoundary[]

  @@map("grading_scales")
}

model GradeBoundary {
  id             Int      @id @default(autoincrement())
  gradingScaleId Int      @map("grading_scale_id")
  minScore       Decimal  @map("min_score") @db.Decimal(5, 2)
  maxScore       Decimal  @map("max_score") @db.Decimal(5, 2)
  grade          String   // A, B, C...
  gradePoint     Decimal? @map("grade_point") @db.Decimal(3, 2) // 4.0, 5.0 scale
  remark         String?
  orderIndex     Int      @map("order_index")
  createdAt      DateTime @default(now()) @map("created_at")

  scale          GradingScale @relation(fields: [gradingScaleId], references: [id])

  @@map("grade_boundaries")
}

// --- SKILLS & BEHAVIORAL LAYER ---

model SkillCategory {
  id         Int      @id @default(autoincrement())
  name       String   // e.g., "Affective Domain", "Psychomotor Skills"
  orderIndex Int      @map("order_index")
  items      SkillItem[]

  @@map("skill_categories")
}

model SkillItem {
  id              Int      @id @default(autoincrement())
  skillCategoryId Int      @map("skill_category_id")
  name            String   // e.g., "Punctuality", "Honesty", "Drawing"
  maxScore        Decimal? @map("max_score") @db.Decimal(5, 2)
  orderIndex      Int      @map("order_index")

  category        SkillCategory @relation(fields: [skillCategoryId], references: [id])
  assessments     StudentSkillAssessment[]

  @@map("skill_items")
}

model StudentSkillAssessment {
  id            Int      @id @default(autoincrement())
  resultSheetId Int      @map("result_sheet_id")
  studentId     Int      @map("student_id")
  skillItemId   Int      @map("skill_item_id")
  
  score         Decimal? @db.Decimal(5, 2)
  grade         String?
  remark        String?
  createdAt     DateTime @default(now()) @map("created_at")

  resultSheet   ResultSheet @relation(fields: [resultSheetId], references: [id])
  skillItem     SkillItem   @relation(fields: [skillItemId], references: [id])

  @@unique([resultSheetId, studentId, skillItemId])
  @@map("student_skill_assessments")
}

model StudentResultSummary {
  id            Int      @id @default(autoincrement())
  resultSheetId Int      @map("result_sheet_id")
  studentId     Int      @map("student_id")
  
  totalScore    Decimal  @db.Decimal(10, 2)
  average       Decimal  @db.Decimal(5, 2)
  gpa           Decimal? @db.Decimal(4, 2)
  
  positionInArm   Int?   @map("position_in_arm")
  positionInLevel Int?   @map("position_in_level")
  totalSubjects   Int    @map("total_subjects")
  
  createdAt     DateTime @default(now()) @map("created_at")

  resultSheet   ResultSheet @relation(fields: [resultSheetId], references: [id])
  // student       Student     @relation(fields: [studentId], references: [id]) 
  // (Uncomment above once Student model is ready)

  @@unique([resultSheetId, studentId])
  @@map("student_result_summaries")
}

model StudentCumulativeSummary {
  id            Int      @id @default(autoincrement())
  resultSheetId Int      @map("result_sheet_id") // Usually an ANNUAL sheet
  studentId     Int      @map("student_id")
  
  cumulativeTotal   Decimal  @map("cumulative_total") @db.Decimal(10, 2)
  cumulativeAverage Decimal  @map("cumulative_average") @db.Decimal(5, 2)
  cumulativeGpa     Decimal? @map("cumulative_gpa") @db.Decimal(4, 2)
  
  promotionStatus   String?  @map("promotion_status") // PROMOTED, PROMOTED_ON_TRIAL, REPEATED
  positionInLevel   Int?     @map("position_in_level")
  
  createdAt     DateTime @default(now()) @map("created_at")

  resultSheet   ResultSheet @relation(fields: [resultSheetId], references: [id])

  @@unique([resultSheetId, studentId])
  @@map("student_cumulative_summaries")
}