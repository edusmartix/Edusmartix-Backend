{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "assets": [
      { "include": "core/mail/views/**/*", "outDir": "dist/src/core/mail/views" }
    ],
    "watchAssets": true
  }
}
